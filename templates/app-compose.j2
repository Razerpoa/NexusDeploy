services:
  {{ manifest.project_name }}:
    image: {{ manifest.image }}
    container_name: {{ manifest.project_name }}
    restart: unless-stopped

    # No host port mapping to avoid conflict with host-mode Gateway (host network_mode).
    # Application is accessed via Docker network by the Gateway.

    {% if manifest.env_vars %}
    environment:
      {% for key, value in manifest.env_vars.items() %}
      - {{ key }}={{ value }}
      {% endfor %}
    {% endif %}

    {% if manifest.infrastructure.volumes %}
    volumes:
      {% for vol in manifest.infrastructure.volumes %}
      - {{ vol.host_path }}:{{ vol.container_path }}
      {% endfor %}
    {% endif %}

    networks:
      - default
      {% if manifest.infrastructure.networks %}
      {% for net in manifest.infrastructure.networks %}
      - {{ net.name }}
      {% endfor %}
      {% endif %}

{% if manifest.infrastructure.networks or manifest.infrastructure.volumes %}
{% if manifest.infrastructure.volumes %}
{% set ns = namespace(has_named=false) %}
{% for vol in manifest.infrastructure.volumes %}
  {% if not (vol.host_path.startswith('/') or vol.host_path.startswith('./') or vol.host_path.startswith('~/')) %}
    {% set ns.has_named = true %}
  {% endif %}
{% endfor %}

{% if ns.has_named %}
volumes:
  {% for vol in manifest.infrastructure.volumes %}
  {% if not (vol.host_path.startswith('/') or vol.host_path.startswith('./') or vol.host_path.startswith('~/')) %}
  {{ vol.host_path }}:
    external: true
  {% endif %}
  {% endfor %}
{% endif %}
{% endif %}

{% if manifest.infrastructure.networks %}
networks:
  {% for net in manifest.infrastructure.networks %}
  {{ net.name }}:
    external: true
  {% endfor %}
{% endif %}
{% endif %}
